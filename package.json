{
  "name": "gradient-text-gen",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "gradient-text-gen": "dist-cli/cli.js"
  },
  "scripts": {
    "dev": "vite",
    "clean": "tsx build/clean.ts",
    "build": "npm run clean && npm run build:web && npm run build:worker && npm run build:cli",
    "build:web": "vite build",
    "build:worker": "tsc -p tsconfig.worker.json",
    "build:cli": "tsc -p tsconfig.cli.json",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.cli.json --noEmit",
    "test": "tsx --test src/*.test.ts worker/*.test.ts",
    "cli": "tsx src/cli.ts",
    "preview": "vite preview"
  },
  "dependencies": {
    "@vitejs/plugin-react": "5.0.4",
    "lucide-react": "^0.468.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "vite": "6.4.2"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3"
  }
}
